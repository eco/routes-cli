{
  "name": "eco-routes-cli",
  "version": "1.0.5",
  "description": "CLI tool for publishing intents to EVM, TVM, and SVM chains",
  "main": "bundle/index.js",
  "bin": {
    "eco-routes-cli": "./bundle/index.js"
  },
  "files": [
    "bundle",
    "scripts/postinstall.js",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc --noEmit && ncc build src/main.ts -o bundle --no-cache",
    "dev": "ts-node --transpile-only -r tsconfig-paths/register src/main.ts",
    "dev:testnet": "NODE_CHAINS_ENV=development ts-node --transpile-only -r tsconfig-paths/register src/main.ts",
    "start": "node bundle/index.js",
    "clean": "rm -rf dist bundle",
    "test": "jest",
    "test:unit": "jest --testPathPattern='tests/(core|config|blockchain)'",
    "test:integration": "jest --testPathPattern='tests/integration'",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "jest --config jest.e2e.config.ts",
    "test:e2e:ci": "jest --config jest.e2e.config.ts --forceExit",
    "lint": "eslint src tests --ext .ts",
    "lint:fix": "eslint src tests --ext .ts --fix",
    "format": "prettier --write src tests",
    "format:check": "prettier --check src tests",
    "typecheck": "tsc --noEmit",
    "prepare": "husky",
    "docs": "typedoc",
    "postinstall": "node scripts/postinstall.js"
  },
  "keywords": [
    "blockchain",
    "intent",
    "cli",
    "evm",
    "tvm",
    "svm"
  ],
  "author": "Eco Protocol",
  "license": "MIT",
  "dependencies": {
    "@coral-xyz/anchor": "^0.32.1",
    "@nestjs/common": "^11.1.14",
    "@nestjs/config": "^4.0.3",
    "@nestjs/core": "^11.1.14",
    "@solana/spl-token": "^0.4.14",
    "@solana/web3.js": "^1.91.8",
    "chalk": "^4.1.2",
    "cli-table3": "^0.6.5",
    "dotenv": "^16.4.5",
    "inquirer": "^8.2.6",
    "nest-commander": "^3.20.1",
    "ora": "^5.4.1",
    "reflect-metadata": "^0.2.2",
    "tronweb": "^6.2.0",
    "viem": "^2.40.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@types/bn.js": "^5.2.0",
    "@types/inquirer": "^8.2.10",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.16.16",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "@vercel/ncc": "^0.38.4",
    "eslint": "^10.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "lint-staged": "^16.1.6",
    "prettier": "^3.6.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.20.5",
    "typedoc": "^0.28.17",
    "typescript": "^5.7.2"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "packageManager": "pnpm@9.15.9+sha512.68046141893c66fad01c079231128e9afb89ef87e2691d69e4d40eee228988295fd4682181bae55b58418c3a253bde65a505ec7c5f9403ece5cc3cd37dcf2531",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "pnpm": {
    "overrides": {
      "axios": ">=1.13.5",
      "minimatch": ">=10.2.1",
      "test-exclude": "8.0.0",
      "bn.js": "5.2.3"
    },
    "auditConfig": {
      "ignoreCves": [
        "GHSA-3gc7-fjrx-p6mg",
        "CVE-2025-3194",
        "GHSA-2g4f-4pwh-qvx6",
        "CVE-2025-69873",
        "GHSA-378v-28hj-76wf",
        "GHSA-2w6w-674q-4c4q",
        "CVE-2026-33937"
      ]
    }
  }
}
